# cto-docsign server — committed template.
# Copy to .env.local (gitignored) and fill in real secrets for local dev,
# or set these in the environment / PM2 on the server.

NODE_ENV=development
PORT=4400

# Public base URL of this app (used to build share/signing links in emails).
APP_BASE_URL=http://localhost:4400

# --- Database (Postgres) -------------------------------------------------
# Either set DATABASE_URL, or the discrete DB_* vars below.
# DATABASE_URL=postgres://user:pass@localhost:5432/docsign
DB_HOST=localhost
DB_PORT=5432
DB_NAME=docsign
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# --- Auth ----------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Set to true to require email verification before a sender can log in.
REQUIRE_EMAIL_VERIFICATION=false
# Comma-separated allowlist for self-signup. Empty = anyone may register.
# e.g. SIGNUP_ALLOWED_DOMAINS=cryptool.io,unified.vip
SIGNUP_ALLOWED_DOMAINS=

# --- Viewer/Signer tokens (recipients, not app users) --------------------
DOCROOM_VIEWER_SECRET=change-me-viewer-secret
DOCROOM_VIEWER_TOKEN_TTL=2h
DOCROOM_SIGNER_TOKEN_TTL=1h

# --- File storage --------------------------------------------------------
# s3 | local
DOCROOM_STORAGE_DRIVER=local
DOCROOM_LOCAL_STORAGE_PATH=./storage/docroom
# S3 (only used when DOCROOM_STORAGE_DRIVER=s3)
DOCROOM_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Email (SMTP via nodemailer) -----------------------------------------
# Used for system emails (verification, OTP, view notices) and as the fallback
# sender. If MAIL_HOST is blank, these are logged to the console (dry-run).
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_NAME=Cryptool DocSign
MAIL_FROM_EMAIL=info@cryptool.io

# --- Connect-your-mailbox (OAuth) ----------------------------------------
# Lets users connect Gmail/Outlook so "Please sign" emails go out FROM their own
# address, through their own mailbox. Requires OAuth apps you register with each
# provider (see DEPLOY.md "Connecting sender mailboxes"). Blank = feature shown
# but disabled ("not configured"). Redirect URIs must be:
#   {APP_BASE_URL}/api/oauth/google/callback
#   {APP_BASE_URL}/api/oauth/microsoft/callback
# 32-byte base64 key that encrypts stored refresh tokens at rest:
EMAIL_TOKEN_ENC_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- CORS ----------------------------------------------------------------
# Comma-separated origins allowed to call the API (the built SPA is same-origin).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4400

# --- Auto-deploy webhook -------------------------------------------------
# Shared secret between the GitHub push webhook and this server. Set the SAME
# value here (in .env.local) and in the repo's webhook config. Leave blank to disable.
GITHUB_WEBHOOK_SECRET=
DEPLOY_BRANCH=master
